# Database
DATABASE_URL="file:./dev.db"

# --- Part 2 integrations (all optional; the app falls back gracefully) ---

# A) Suno — music generation
SUNO_API_KEY=
# Optional: override the Suno provider base URL
# SUNO_API_BASE="https://api.sunoapi.org"
# Optional: public callback URL some Suno providers require
# SUNO_CALLBACK_URL=

# B) Cala — company data enrichment
CALA_API_KEY=
# CALA_API_BASE="https://api.cala.ai"

# C) Vapi — voice input (public key is exposed to the browser)
VAPI_PUBLIC_KEY=
# Optional: a pre-built Vapi assistant id (otherwise an inline assistant is used)
VAPI_ASSISTANT_ID=

# D) Twilio — SMS reminders
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# E) Stripe — "Unlock Prime mode — €1"
STRIPE_SECRET_KEY=

# Base URL used to build SMS deep links (optional)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
